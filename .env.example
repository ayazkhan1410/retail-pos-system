# Copy to .env on your machine AND on the client PC:
#   cp .env.example .env

# --- PostgreSQL ---
POSTGRES_DB=smartshop
POSTGRES_USER=smartshop
POSTGRES_PASSWORD=change-me-use-strong-password
# Host port exposed on your machine (default 5433 if 5432 is used by another project)
POSTGRES_PORT=5433

# Local venv: leave POSTGRES_HOST unset → SQLite (migrate / createsuperuser)
# Docker: compose sets POSTGRES_HOST=db for backend service
# Local Postgres: POSTGRES_HOST=localhost

# --- Django ---
DJANGO_SECRET_KEY=change-me-generate-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_TIME_ZONE=Asia/Karachi

# Comma-separated origins (docker FE on :3000, vite dev on :5173)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# --- App version / updates ---
APP_VERSION=0.1.0
LATEST_APP_VERSION=0.1.0
UPDATE_RELEASE_NOTES=Initial release

# Backup folder inside backend container (mapped to ./backups on host)
BACKUP_DIR=/app/backups
